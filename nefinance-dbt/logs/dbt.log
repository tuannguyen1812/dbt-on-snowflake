    from PC_FIVETRAN_DB.GOOGLE_DRIVE.SP_500_HISTORICAL_DATA
) , 
deduplicated as (

    select *
    from source
    qualify row_number() over (
        partition by ticker, price_date 
        order by fivetran_synced_at desc, source_line_number desc
    ) = 1

)

select * from deduplicated
  );
