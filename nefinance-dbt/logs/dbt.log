[0m17:07:51.624495 [debug] [Thread-2 (]: On model.nefinance_intelligence.financial_news: /* {"app": "dbt", "dbt_version": "1.9.4", "profile_name": "nefinance_intelligence", "target_name": "dev", "node_id": "model.nefinance_intelligence.financial_news"} */
create or replace   view NEFINANCE_DB.DEV.financial_news
  
   as (
    with cnbc as (

    select
        'cnbc' as source,
        headlines as headline,
        description,

        -- extract only: Tue, 14 Aug 2018
        try_to_date(
            regexp_substr(time, '[A-Za-z]{3},\\s*[0-9]{1,2}\\s*[A-Za-z]{3}\\s*[0-9]{4}'),
            'DY, DD MON YYYY'
        ) as published_date,

        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.CNBC_HEADLINES
    where time is not null and trim(time) <> ''

),

reuters as (

    select
        'reuters' as source,
        headlines as headline,
        description,

        try_to_date(trim(time), 'MON DD YYYY') as published_date,

        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.REUTERS_HEADLINES

),

guardian as (

    select
        'guardian' as source,
        headlines as headline,
        null as description,

        try_to_date(trim(time), 'DD-MON-YY') as published_date,

        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.GUARDIAN_HEADLINES
    where time is not null and trim(time) <> ''

),
data_union as (
select * from cnbc
union all
select * from reuters
union all
select * from guardian) 
SELECT *, 
CASE
        WHEN SNOWFLAKE.CORTEX.SENTIMENT(CONCAT(headline, '. ', description)) >= 0.3 THEN 'Positive'
        WHEN SNOWFLAKE.CORTEX.SENTIMENT(CONCAT(headline, '. ', description)) <= -0.3 THEN 'Negative'
        ELSE 'Neutral'
    END AS sentiment
    
FROM data_union
WHERE published_date is not null and published_date <> ''
  );
