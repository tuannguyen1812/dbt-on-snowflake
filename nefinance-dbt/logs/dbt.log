create or replace   view NEFINANCE_DB.DEV.financial_news
  
   as (
    with cnbc as (

    select
        'cnbc' as source,
        headlines as headline,
        description,
        try_to_date(time) as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.CNBC_HEADLINES

),

reuters as (

    select
        'reuters' as source,
        headlines as headline,
        description,
        try_to_date(time) as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.REUTERS_HEADLINES

),

guardian as (

    select
        'guardian' as source,
        headlines as headline,

        null as description,   -- missing column FIX

        try_to_date(time) as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.GUARDIAN_HEADLINES

)

select * from cnbc
union all
select * from reuters
union all
select * from guardian
  );
