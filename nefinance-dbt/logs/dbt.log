        net_income_loss,

        liabilities,

        _fivetran_synced as loaded_at

    from source

),

deduplicated as (

    select *

    from renamed

    qualify row_number() over (

        partition by
            ticker,
            fiscal_year,
            report_date

        order by loaded_at desc

    ) = 1

)

select *
from deduplicated
  );
