   as (
    -- stg_sp500_prices.sql
with source as (
    select _line as source_line_number, 
            cast(_fivetran_synced as timestamp_tz(9)) as fivetran_synced_at,
             cast(ticker as varchar(256)) as ticker,
             Date  as price_date,
        cast(open as float) as open_price,
