        'cnbc' as source,
        headlines as headline,
        description,
        try_to_date(regexp_substr(time, '[A-Za-z]{3},\\s\\d{1,2}\\s[A-Za-z]{3}\\s\\d{4}'),
                        'DY, DD MON YYYY') as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.CNBC_HEADLINES
    WHERE time is not null and time <> ''

),

reuters as (

    select
        'reuters' as source,
        headlines as headline,
        description,
        try_to_date(time, 'MON DD YYYY') as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.REUTERS_HEADLINES
    

),

guardian as (

    select
        'guardian' as source,
        headlines as headline,

        null as description,   -- missing column FIX

       try_to_date(time, 'DD-MON-YY') as published_date,
        _fivetran_synced as loaded_at

    from PC_FIVETRAN_DB.GOOGLE_DRIVE.GUARDIAN_HEADLINES
    WHERE time is not null and time <> ''
    
)

